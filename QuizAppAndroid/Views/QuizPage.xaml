<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizAppAndroid.Views.QuizPage"
             Title="Quiz">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label x:Name="QuestionLabel"
               FontSize="20"/>

        <Button Text="Option A" Clicked="OnAnswerClicked"/>
        <Button Text="Option B" Clicked="OnAnswerClicked"/>
        <Button Text="Option C" Clicked="OnAnswerClicked"/>
        <Button Text="Option D" Clicked="OnAnswerClicked"/>

    </VerticalStackLayout>
</ContentPage>