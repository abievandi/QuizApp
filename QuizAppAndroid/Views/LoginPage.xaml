<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Class="CodeLingoAPI.Views.LoginPage"
             Title="Login">

    <VerticalStackLayout Padding="40" Spacing="20" VerticalOptions="Center">

        <!-- Title -->
        <Label Text="CodeLingo"
               FontSize="36"
               FontAttributes="Bold"
               TextColor="Blue"
               HorizontalOptions="Center"/>

        <Label Text="Login to continue"
               FontSize="16"
               TextColor="Gray"
               HorizontalOptions="Center"/>

        <!-- Email -->
        <Entry x:Name="EmailEntry"
               Placeholder="Enter your email"
               Keyboard="Email"/>

        <!-- Password -->
        <Entry x:Name="PasswordEntry"
               Placeholder="Enter your password"
               IsPassword="True"/>

        <!-- Error message -->
        <Label x:Name="ErrorLabel"
               TextColor="Red"
               IsVisible="False"
               HorizontalOptions="Center"/>

        <!-- Login Button -->
        <Button Text="Login"
                Clicked="OnLoginClicked"
                BackgroundColor="Blue"
                TextColor="White"
                CornerRadius="10"/>

    </VerticalStackLayout>

</ContentPage>