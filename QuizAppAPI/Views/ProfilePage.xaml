<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Class="Quiz.Views.ProfilePage"
             Title="History">

    <StackLayout Padding="10">

        <Label Text="Past Results"
               FontSize="24"
               HorizontalOptions="Center"/>

        <CollectionView x:Name="ResultsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Margin="5">
                        <StackLayout>
                            <Label Text="{Binding Score}" FontSize="18"/>
                            <Label Text="{Binding TakenAt}" FontSize="12"/>
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>
</ContentPage>